# Public Expo variables. Safe to reference from the mobile client.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-only variables. Never expose these from Expo client code.
SUPABASE_SERVICE_ROLE_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Payment integration is backend-owned. Keep secrets server-side.
PAYMENT_PROVIDER_SECRET_KEY=

# Local/backend environment marker. Do not read from mobile client unless renamed to EXPO_PUBLIC_... intentionally.
APP_ENV=development
